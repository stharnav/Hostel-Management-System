# Server Config
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_string

# Firebase Admin SDK
# Path to service account key JSON file you download from Firebase Console:
# Project Settings -> Service Accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# Firebase Storage bucket (e.g. your-project-id.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Optional: bootstrap an initial admin user the first time the server starts
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_NAME=Admin
