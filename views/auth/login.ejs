<div class="w-full max-w-md">
  <div class="rounded-2xl bg-white p-8 shadow-2xl">
    <div class="mb-8 text-center">
      <% if (brand && brand.iconUrl) { %>
        <img src="<%= brand.iconUrl %>" alt="" class="mx-auto mb-4 h-14 w-14 rounded-2xl object-cover shadow-lg" />
      <% } else { %>
        <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-600 text-white">
          <i class="bi bi-building text-2xl"></i>
        </div>
      <% } %>
      <h1 class="text-2xl font-bold text-ink-900">Welcome back</h1>
      <p class="mt-1 text-sm text-ink-500">Sign in to your <%= brand && brand.appName ? brand.appName : 'Hostel Manager' %> account</p>
    </div>

    <form method="POST" action="/auth/login" class="space-y-5">
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Email address</label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-ink-400">
            <i class="bi bi-envelope"></i>
          </span>
          <input type="email" name="email" required autofocus
                 placeholder="you@example.com"
                 class="w-full rounded-lg border border-ink-200 bg-ink-50 py-2.5 pl-10 pr-3 text-sm text-ink-900 placeholder-ink-400 focus:border-brand-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-100" />
        </div>
      </div>

      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Password</label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-ink-400">
            <i class="bi bi-lock"></i>
          </span>
          <input type="password" name="password" required
                 placeholder="••••••••"
                 class="w-full rounded-lg border border-ink-200 bg-ink-50 py-2.5 pl-10 pr-3 text-sm text-ink-900 placeholder-ink-400 focus:border-brand-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-100" />
        </div>
      </div>

      <button type="submit"
              class="flex w-full items-center justify-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2">
        <i class="bi bi-box-arrow-in-right"></i>
        Sign in
      </button>
    </form>

    <p class="mt-6 text-center text-xs text-ink-400">
      <%= brand && brand.appName ? brand.appName : 'Hostel Management System' %> &copy; <%= new Date().getFullYear() %>
    </p>
  </div>
</div>
