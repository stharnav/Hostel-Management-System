<div class="w-full max-w-sm">
  <div class="rounded-2xl bg-white shadow-soft p-8">
    <div class="text-center mb-8">
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-red-100 text-red-700 mb-4">
        <i class="bi bi-shield-lock text-3xl"></i>
      </div>
      <h1 class="text-2xl font-bold text-ink-900">Super Admin</h1>
      <p class="text-ink-500 mt-2">System administration access</p>
    </div>

    <form action="/admin/auth/login" method="POST" class="space-y-5">
      <div>
        <label for="email" class="block text-sm font-semibold text-ink-700 mb-1.5">Email</label>
        <input type="email" id="email" name="email" required autofocus
               class="w-full rounded-lg border border-ink-300 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition"
               placeholder="admin@example.com" />
      </div>

      <div>
        <label for="password" class="block text-sm font-semibold text-ink-700 mb-1.5">Password</label>
        <input type="password" id="password" name="password" required
               class="w-full rounded-lg border border-ink-300 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition"
               placeholder="Password" />
      </div>

      <button type="submit"
              class="w-full rounded-lg bg-red-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-red-700 transition">
        Sign In
      </button>
    </form>

    <div class="mt-6 text-center">
      <a href="/" class="text-sm text-ink-400 hover:text-ink-600 transition">
        <i class="bi bi-arrow-left mr-1"></i>Back to hostels
      </a>
    </div>
  </div>
</div>
