<div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <h2 class="text-2xl font-bold text-ink-900">Activity Log</h2>
    <p class="mt-1 text-sm text-ink-500">A chronological trail of who did what across the hostel system.</p>
  </div>
  <div class="flex items-center gap-2 text-xs text-ink-500">
    <i class="bi bi-clock-history"></i>
    Showing page <span class="font-semibold text-ink-700"><%= page %></span>
    <% if (hasMore) { %>
      <span class="rounded-full bg-amber-50 px-2 py-0.5 font-medium text-amber-700">more available</span>
    <% } else { %>
      <span class="rounded-full bg-emerald-50 px-2 py-0.5 font-medium text-emerald-700">up to date</span>
    <% } %>
  </div>
</div>

<!-- Filter bar -->
<form method="get" action="<%= basePath %>/logs" class="mb-6 rounded-2xl border border-ink-200 bg-white p-4 shadow-card">
  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-5">
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-ink-500">Group</label>
      <select name="group" class="w-full rounded-lg border border-ink-200 bg-white px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
        <option value="">All groups</option>
        <% options.groups.forEach(function(g) { %>
          <option value="<%= g.group %>" <%= filters.group === g.group ? 'selected' : '' %>><%= g.label %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-ink-500">Action</label>
      <select name="action" class="w-full rounded-lg border border-ink-200 bg-white px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
        <option value="">All actions</option>
        <% options.groups.forEach(function(g) { %>
          <optgroup label="<%= g.label %>">
            <% g.actions.forEach(function(a) { %>
              <option value="<%= a.key %>" <%= filters.action === a.key ? 'selected' : '' %>><%= a.label %></option>
            <% }) %>
          </optgroup>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-ink-500">Actor</label>
      <select name="actor" class="w-full rounded-lg border border-ink-200 bg-white px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500">
        <option value="">Anyone</option>
        <% options.actors.forEach(function(a) { %>
          <option value="<%= a.id %>" <%= filters.actor === a.id ? 'selected' : '' %>>
            <%= a.name %><%= a.role ? ' (' + a.role + ')' : '' %>
          </option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-ink-500">From</label>
      <input type="date" name="from" value="<%= filters.from %>"
             class="w-full rounded-lg border border-ink-200 bg-white px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
    </div>
    <div>
      <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-ink-500">To</label>
      <input type="date" name="to" value="<%= filters.to %>"
             class="w-full rounded-lg border border-ink-200 bg-white px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500" />
    </div>
  </div>
  <div class="mt-3 flex flex-wrap items-center justify-end gap-2">
    <%# Resetting wipes every query param back to the default view. %>
    <a href="<%= basePath %>/logs" class="rounded-lg border border-ink-200 bg-white px-3 py-1.5 text-sm font-medium text-ink-600 transition hover:bg-ink-50">
      Clear
    </a>
    <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-brand-600 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-brand-700">
      <i class="bi bi-funnel-fill"></i>
      Apply filters
    </button>
  </div>
</form>

<!-- Feed -->
<div class="rounded-2xl border border-ink-200 bg-white shadow-card">
  <% if (!items.length) { %>
    <div class="flex flex-col items-center justify-center px-6 py-16 text-center">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-ink-100 text-ink-500">
        <i class="bi bi-inbox text-2xl"></i>
      </div>
      <h3 class="mt-4 text-base font-semibold text-ink-900">No activity yet</h3>
      <p class="mt-1 max-w-sm text-sm text-ink-500">
        Once people start adding students, rooms, payments, and so on, every action will show up here.
      </p>
    </div>
  <% } else { %>
    <ul class="divide-y divide-ink-100">
      <% items.forEach(function(it) { %>
        <li class="flex gap-4 px-5 py-4 transition hover:bg-ink-50/60">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl ring-1 <%= it.color.bg %> <%= it.color.text %> <%= it.color.ring %>">
            <i class="bi <%= it.meta.icon %> text-lg"></i>
          </div>
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-baseline gap-x-2">
              <span class="text-sm font-semibold text-ink-900">
                <%= it.actor && it.actor.name ? it.actor.name : 'System' %>
              </span>
              <span class="text-sm text-ink-600">
                <%= it.meta.label.toLowerCase() %>
              </span>
              <% if (it.summary) { %>
                <span class="text-sm text-ink-700">— <%= it.summary %></span>
              <% } %>
            </div>
            <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-ink-500">
              <span title="<%= it.whenAbsolute %>" class="inline-flex items-center gap-1">
                <i class="bi bi-clock"></i> <%= it.when %>
              </span>
              <% if (it.actor && it.actor.role) { %>
                <span class="inline-flex items-center gap-1 rounded-full bg-ink-100 px-2 py-0.5 font-medium text-ink-700">
                  <%= it.actor.role %>
                </span>
              <% } %>
              <% if (it.entity) { %>
                <span class="inline-flex items-center gap-1">
                  <i class="bi bi-link-45deg"></i>
                  <%= it.entity %><%= it.entityId ? ' · ' + it.entityId.slice(0, 8) : '' %>
                </span>
              <% } %>
              <% if (it.ip) { %>
                <span class="inline-flex items-center gap-1">
                  <i class="bi bi-globe"></i> <%= it.ip %>
                </span>
              <% } %>
            </div>
            <% if (it.details && Object.keys(it.details).length) { %>
              <details class="mt-2">
                <summary class="cursor-pointer text-xs font-medium text-brand-700 hover:text-brand-800">Details</summary>
                <pre class="mt-2 max-h-48 overflow-auto rounded-lg bg-ink-50 p-3 text-xs text-ink-700"><%= JSON.stringify(it.details, null, 2) %></pre>
              </details>
            <% } %>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>

  <%# Pagination footer. Prev / Next only — keeps the URL small and avoids
      a giant numbered pager for the rare case of long histories. %>
  <% if (items.length || page > 1) { %>
    <div class="flex items-center justify-between border-t border-ink-100 px-5 py-3 text-sm">
      <div class="text-ink-500">
        Page <span class="font-semibold text-ink-700"><%= page %></span>
      </div>
      <div class="flex items-center gap-2">
        <% if (page > 1) { %>
          <a href="<%= pageUrl(req, page - 1) %>"
             class="inline-flex items-center gap-1 rounded-lg border border-ink-200 bg-white px-3 py-1.5 font-medium text-ink-700 transition hover:bg-ink-50">
            <i class="bi bi-chevron-left"></i> Newer
          </a>
        <% } %>
        <% if (hasMore) { %>
          <a href="<%= pageUrl(req, page + 1) %>"
             class="inline-flex items-center gap-1 rounded-lg border border-ink-200 bg-white px-3 py-1.5 font-medium text-ink-700 transition hover:bg-ink-50">
            Older <i class="bi bi-chevron-right"></i>
          </a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>

<%# Helper for building paginated URLs that preserve filters. %>
<% function pageUrl(req, p) { %>
  <% const parts = []; %>
  <% Object.keys(req.query || {}).forEach(function(k) { %>
    <% const v = req.query[k]; if (v != null && v !== '' && k !== 'page') parts.push(encodeURIComponent(k) + '=' + encodeURIComponent(String(v))); %>
  <% }); %>
  <% parts.push('page=' + p); %>
  <% return basePath + '/logs?' + parts.join('&'); %>
<% } %>
