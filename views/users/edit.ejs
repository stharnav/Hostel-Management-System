<% if (tenantInactive) { %>
<div class="rounded-2xl border border-ink-200 bg-white p-12 text-center shadow-card">
  <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-amber-100 text-amber-600">
    <i class="bi bi-lock-fill text-3xl"></i>
  </div>
  <h3 class="text-base font-semibold text-ink-900">Hostel is inactive</h3>
  <p class="mt-1 text-sm text-ink-500">You cannot edit users while the hostel is inactive.</p>
  <a href="<%= basePath %>/users" class="mt-4 inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">
    <i class="bi bi-arrow-left"></i> Back to users
  </a>
</div>
<% } else { %>

<div class="mb-6">
  <h2 class="text-2xl font-bold text-ink-900">Edit User</h2>
  <p class="mt-1 text-sm text-ink-500">Update account details, role, and dietary preference</p>
</div>

<form method="POST" action="<%= basePath %>/users/<%= user.id %>?_method=PUT" class="space-y-6">
  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Name *</label>
        <input name="name" required value="<%= user.name %>"
               class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Email *</label>
        <input type="email" name="email" required value="<%= user.email %>"
               class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">New password</label>
        <input type="password" name="password" minlength="6" placeholder="Leave blank to keep current"
               class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
        <p class="mt-1 text-xs text-ink-500">Only fill in to reset. Minimum 6 characters.</p>
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Role *</label>
        <select name="roleId" required class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100">
          <% roles.forEach(function(r) { %>
            <option value="<%= r.id %>" <%= user.roleId === r.id ? 'selected' : '' %>>
              <%= r.name %><%= r.isSystem ? '' : ' (custom)' %>
            </option>
          <% }) %>
        </select>
        <p class="mt-1 text-xs text-ink-500">
          Need a different role?
          <a href="<%= basePath %>/settings/roles" class="font-medium text-brand-600 hover:underline">Manage roles</a>
        </p>
        <input type="hidden" name="role" value="<%= user.role || 'staff' %>" />
      </div>
      <div class="md:col-span-2">
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Dietary preference (for kitchen)</label>
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-3">
          <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-ink-200 px-3 py-2.5 text-sm hover:bg-ink-50 has-[:checked]:border-emerald-300 has-[:checked]:bg-emerald-50">
            <input type="radio" name="dietary" value="veg" <%= (!user.dietary || user.dietary === 'veg') ? 'checked' : '' %> class="text-emerald-600 focus:ring-emerald-500" />
            <span class="flex h-7 w-7 items-center justify-center rounded-md bg-emerald-100 text-emerald-700">
              <i class="bi bi-egg-fried"></i>
            </span>
            <span class="font-medium text-ink-900"><%= dietLabels.veg %></span>
          </label>
          <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-ink-200 px-3 py-2.5 text-sm hover:bg-ink-50 has-[:checked]:border-red-300 has-[:checked]:bg-red-50">
            <input type="radio" name="dietary" value="nonveg" <%= user.dietary === 'nonveg' ? 'checked' : '' %> class="text-red-600 focus:ring-red-500" />
            <span class="flex h-7 w-7 items-center justify-center rounded-md bg-red-100 text-red-700">
              <i class="bi bi-fire"></i>
            </span>
            <span class="font-medium text-ink-900"><%= dietLabels.nonveg %></span>
          </label>
          <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-ink-200 px-3 py-2.5 text-sm hover:bg-ink-50 has-[:checked]:border-amber-300 has-[:checked]:bg-amber-50">
            <input type="radio" name="dietary" value="eggOnly" <%= user.dietary === 'eggOnly' ? 'checked' : '' %> class="text-amber-600 focus:ring-amber-500" />
            <span class="flex h-7 w-7 items-center justify-center rounded-md bg-amber-100 text-amber-700">
              <i class="bi bi-egg-fill"></i>
            </span>
            <span class="font-medium text-ink-900"><%= dietLabels.eggOnly %></span>
          </label>
        </div>
        <p class="mt-1 text-xs text-ink-500">Used by the kitchen dashboard to plan meals.</p>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <a href="<%= basePath %>/users" class="rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm font-semibold text-ink-700 hover:bg-ink-50">Cancel</a>
    <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700">
      <i class="bi bi-check2"></i> Save changes
    </button>
  </div>
</form>

<% } %>
