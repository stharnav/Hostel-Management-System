<div class="mb-6">
  <h2 class="text-2xl font-bold text-ink-900">Add User</h2>
  <p class="mt-1 text-sm text-ink-500">Create a new admin or staff account</p>
</div>

<form method="POST" action="/users" class="space-y-6">
  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Name *</label>
        <input name="name" required class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Email *</label>
        <input type="email" name="email" required class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Password *</label>
        <input type="password" name="password" required minlength="6" class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
        <p class="mt-1 text-xs text-ink-500">Minimum 6 characters</p>
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Role *</label>
        <select name="role" required class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100">
          <option value="staff">Staff</option>
          <option value="admin">Admin</option>
        </select>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <a href="/users" class="rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm font-semibold text-ink-700 hover:bg-ink-50">Cancel</a>
    <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700">
      <i class="bi bi-check2"></i> Create User
    </button>
  </div>
</form>
