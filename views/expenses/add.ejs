<% if (tenantInactive) { %>
<div class="rounded-2xl border border-ink-200 bg-white p-12 text-center shadow-card">
  <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-amber-100 text-amber-600">
    <i class="bi bi-lock-fill text-3xl"></i>
  </div>
  <h3 class="text-base font-semibold text-ink-900">Hostel is inactive</h3>
  <p class="mt-1 text-sm text-ink-500">You cannot add expenses while the hostel is inactive.</p>
  <a href="<%= basePath %>/expenses" class="mt-4 inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">
    <i class="bi bi-arrow-left"></i> Back to expenses
  </a>
</div>
<% } else { %>

<div class="mb-6">
  <h2 class="text-2xl font-bold text-ink-900">Add Expense</h2>
  <p class="mt-1 text-sm text-ink-500">Record a new hostel expenditure</p>
</div>

<form method="POST" action="<%= basePath %>/expenses" class="space-y-6">
  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <h3 class="mb-4 flex items-center gap-2 text-base font-semibold text-ink-900">
      <i class="bi bi-receipt-cutoff text-brand-600"></i> Expense Details
    </h3>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Amount (<%= brand.currencySymbol || '₹' %>) <span class="text-red-500">*</span></label>
        <input type="number" name="amount" min="0" step="any" required placeholder="0.00"
               class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Category <span class="text-red-500">*</span></label>
        <select name="category" required class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100">
          <option value="">— Select —</option>
          <% categories.forEach(function(c) { %>
            <option value="<%= c %>"><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Date <span class="text-red-500">*</span></label>
        <input type="date" name="date" value="<%= today %>" required
               class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Vendor / Payee</label>
        <input name="vendor" placeholder="e.g. Local hardware store"
               class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div class="md:col-span-2">
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Description</label>
        <textarea name="description" rows="3" placeholder="What was this expense for?"
                  class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100"></textarea>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <a href="<%= basePath %>/expenses" class="rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm font-semibold text-ink-700 hover:bg-ink-50">Cancel</a>
    <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700">
      <i class="bi bi-check2"></i> Save Expense
    </button>
  </div>
</form>

<% } %>
