<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <a href="/admin/dashboard" class="text-sm text-brand-600 hover:text-brand-700 font-medium">
      <i class="bi bi-arrow-left mr-1"></i>Back to Admin Dashboard
    </a>
  </div>

  <div class="rounded-xl border border-ink-200 bg-white p-8 shadow-soft">
    <h1 class="text-2xl font-bold text-ink-900 mb-6">Edit Hostel: <%= tenant.name %></h1>

    <form action="/admin/tenants/<%= tenant.id %>" method="POST" class="space-y-6">
      <div>
        <label for="name" class="block text-sm font-semibold text-ink-700 mb-1.5">Hostel Name</label>
        <input type="text" id="name" name="name"
               class="w-full rounded-lg border border-ink-300 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition"
               value="<%= tenant.name %>" />
      </div>

      <div>
        <label class="block text-sm font-semibold text-ink-700 mb-1.5">URL Slug</label>
        <div class="flex items-center rounded-lg border border-ink-200 bg-ink-50 px-4 py-2.5">
          <span class="text-ink-400 text-sm">/</span>
          <span class="text-ink-700 text-sm font-medium ml-1"><%= tenant.slug %></span>
        </div>
        <p class="mt-1 text-xs text-ink-400">URL slug cannot be changed.</p>
      </div>

      <div>
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" name="active" value="on"
                 <%= tenant.active ? 'checked' : '' %>
                 class="h-4 w-4 rounded border-ink-300 text-brand-600 focus:ring-brand-500" />
          <span class="text-sm font-semibold text-ink-700">Active</span>
        </label>
        <p class="mt-1 text-xs text-ink-400 ml-7">Inactive hostels cannot be accessed by their users.</p>
      </div>

      <div class="flex items-center gap-3 pt-4">
        <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition">
          <i class="bi bi-check-lg"></i>
          Save Changes
        </button>
        <a href="/admin/dashboard" class="rounded-lg border border-ink-300 px-5 py-2.5 text-sm font-medium text-ink-700 hover:bg-ink-50 transition">
          Cancel
        </a>
      </div>
    </form>

    <div class="mt-8 border-t border-ink-200 pt-6">
      <h2 class="text-lg font-semibold text-red-700 mb-2">Danger Zone</h2>
      <p class="text-sm text-ink-500 mb-4">Deleting this hostel will permanently remove all its data including users, students, rooms, and activity logs.</p>
      <form action="/admin/tenants/<%= tenant.id %>/delete" method="POST"
            onsubmit="return confirm('Are you absolutely sure you want to delete this hostel? This action cannot be undone.')">
        <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700 transition">
          <i class="bi bi-trash"></i>
          Delete Hostel
        </button>
      </form>
    </div>
  </div>
</div>
