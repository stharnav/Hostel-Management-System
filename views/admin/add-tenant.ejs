<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <a href="/admin/dashboard" class="text-sm text-brand-600 hover:text-brand-700 font-medium">
      <i class="bi bi-arrow-left mr-1"></i>Back to Admin Dashboard
    </a>
  </div>

  <div class="rounded-xl border border-ink-200 bg-white p-8 shadow-soft">
    <h1 class="text-2xl font-bold text-ink-900 mb-6">Add New Hostel</h1>

    <form action="/admin/tenants" method="POST" class="space-y-6">
      <div>
        <label for="name" class="block text-sm font-semibold text-ink-700 mb-1.5">Hostel Name *</label>
        <input type="text" id="name" name="name" required
               class="w-full rounded-lg border border-ink-300 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition"
               placeholder="e.g. Sunrise Hostel" />
      </div>

      <div>
        <label for="slug" class="block text-sm font-semibold text-ink-700 mb-1.5">URL Slug</label>
        <div class="flex items-center">
          <span class="text-ink-400 text-sm mr-1">/</span>
          <input type="text" id="slug" name="slug"
                 class="flex-1 rounded-lg border border-ink-300 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition"
                 placeholder="auto-generated-from-name" />
        </div>
        <p class="mt-1 text-xs text-ink-400">Leave blank to auto-generate from the name. Only lowercase letters, numbers, and hyphens.</p>
      </div>

      <div class="border-t border-ink-200 pt-6">
        <h2 class="text-lg font-semibold text-ink-900 mb-4">Admin Account</h2>
        <p class="text-sm text-ink-500 mb-4">This will be the admin login for this specific hostel.</p>

        <div class="space-y-4">
          <div>
            <label for="adminName" class="block text-sm font-semibold text-ink-700 mb-1.5">Admin Name</label>
            <input type="text" id="adminName" name="adminName"
                   class="w-full rounded-lg border border-ink-300 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition"
                   placeholder="Admin" value="Admin" />
          </div>

          <div>
            <label for="adminEmail" class="block text-sm font-semibold text-ink-700 mb-1.5">Admin Email *</label>
            <input type="email" id="adminEmail" name="adminEmail" required
                   class="w-full rounded-lg border border-ink-300 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition"
                   placeholder="admin@hostel.com" />
          </div>

          <div>
            <label for="adminPassword" class="block text-sm font-semibold text-ink-700 mb-1.5">Admin Password *</label>
            <input type="password" id="adminPassword" name="adminPassword" required minlength="6"
                   class="w-full rounded-lg border border-ink-300 px-4 py-2.5 text-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition"
                   placeholder="Min 6 characters" />
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 pt-4">
        <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition">
          <i class="bi bi-plus-lg"></i>
          Create Hostel
        </button>
        <a href="/admin/dashboard" class="rounded-lg border border-ink-300 px-5 py-2.5 text-sm font-medium text-ink-700 hover:bg-ink-50 transition">
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>
