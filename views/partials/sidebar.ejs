<aside id="sidebar"
       class="fixed inset-y-0 left-0 z-40 w-72 transform border-r border-ink-200 bg-white transition-transform duration-300 lg:translate-x-0 -translate-x-full flex flex-col">
  <div class="flex h-16 items-center justify-between border-b border-ink-200 px-6 flex-shrink-0">
    <a href="<%= basePath %>/dashboard" class="flex items-center gap-2">
      <% if (brand && brand.iconUrl) { %>
        <img src="<%= brand.iconUrl %>" alt="" class="h-9 w-9 rounded-lg object-cover ring-1 ring-ink-200" />
      <% } else { %>
        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand-600 text-white">
          <i class="bi bi-building text-lg"></i>
        </span>
      <% } %>
      <span class="text-lg font-bold text-ink-900 truncate"><%= brand && brand.appName ? brand.appName : 'Hostel Manager' %></span>
    </a>
    <button id="sidebar-close" class="lg:hidden text-ink-500 hover:text-ink-800">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto px-4 py-6">
    <% if (isAdminRoute) { %>
      <%# Admin sidebar — super admin panel %>
      <p class="px-3 pb-2 text-xs font-semibold uppercase tracking-wider text-ink-400">Super Admin</p>
      <ul class="space-y-1">
        <li>
          <a href="/admin/dashboard"
             class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                    <%= currentPath === '/admin/dashboard' || currentPath === '/admin' ? 'bg-red-50 text-red-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
            <i class="bi bi-grid-1x2-fill text-lg"></i>
            Dashboard
          </a>
        </li>
        <li>
          <a href="/"
             class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-ink-600 transition hover:bg-ink-100 hover:text-ink-900">
            <i class="bi bi-building text-lg"></i>
            Back to Hostels
          </a>
        </li>
        <li>
          <a href="/admin/profile"
             class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                    <%= currentPath === '/admin/profile' ? 'bg-red-50 text-red-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
            <i class="bi bi-person-circle text-lg"></i>
            My Profile
          </a>
        </li>
        <li>
          <a href="/admin/storage"
             class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                    <%= currentPath === '/admin/storage' ? 'bg-red-50 text-red-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
            <i class="bi bi-hdd-fill text-lg"></i>
            Storage
          </a>
        </li>
        <li>
          <a href="/admin/auth/logout"
             class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-ink-600 transition hover:bg-red-50 hover:text-red-700">
            <i class="bi bi-box-arrow-right text-lg"></i>
            Logout
          </a>
        </li>
      </ul>
    <% } else { %>
      <%# Tenant sidebar %>
      <p class="px-3 pb-2 text-xs font-semibold uppercase tracking-wider text-ink-400">Menu</p>
      <ul class="space-y-1">
        <li>
          <a href="<%= basePath %>/dashboard"
             class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                    <%= currentPath.includes('/dashboard') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
            <i class="bi bi-grid-1x2-fill text-lg"></i>
            Dashboard
          </a>
        </li>
        <% if (can('students.viewList')) { %>
          <li>
            <a href="<%= basePath %>/students"
               class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                      <%= currentPath.includes('/students') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
              <i class="bi bi-people-fill text-lg"></i>
              Students
            </a>
          </li>
        <% } %>
        <% if (can('rooms.view')) { %>
          <li>
            <a href="<%= basePath %>/rooms"
               class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                      <%= currentPath.includes('/rooms') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
              <i class="bi bi-door-closed-fill text-lg"></i>
              Rooms
            </a>
          </li>
        <% } %>
        <% if (can('fees.view')) { %>
          <li>
            <a href="<%= basePath %>/fees"
               class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                      <%= currentPath.includes('/fees') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
              <i class="bi bi-cash-coin text-lg"></i>
              Fees
            </a>
          </li>
        <% } %>
        <% if (can('kitchen.view')) { %>
          <li>
            <a href="<%= basePath %>/kitchen"
               class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                      <%= currentPath.includes('/kitchen') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
              <i class="bi bi-cup-hot-fill text-lg"></i>
              Kitchen
            </a>
          </li>
        <% } %>
        <% if (can('expenses.view')) { %>
          <li>
            <a href="<%= basePath %>/expenses"
               class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                      <%= currentPath.includes('/expenses') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
              <i class="bi bi-receipt-cutoff text-lg"></i>
              Expenses
            </a>
          </li>
        <% } %>
      </ul>

      <p class="mt-8 px-3 pb-2 text-xs font-semibold uppercase tracking-wider text-ink-400">Account</p>
      <ul class="space-y-1">
        <% if (can('logs.view')) { %>
          <li>
            <a href="<%= basePath %>/logs"
               class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                      <%= currentPath.includes('/logs') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
              <i class="bi bi-journal-text text-lg"></i>
              Activity Log
            </a>
          </li>
        <% } %>
        <% if (can('storage.view')) { %>
          <li>
            <a href="<%= basePath %>/settings/storage"
               class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                      <%= currentPath.includes('/settings/storage') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
              <i class="bi bi-hdd-fill text-lg"></i>
              Storage
            </a>
          </li>
        <% } %>
        <% if (currentUser && currentUser.role === 'admin') { %>
          <li>
            <a href="<%= basePath %>/users"
               class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                      <%= currentPath.includes('/users') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
              <i class="bi bi-person-badge-fill text-lg"></i>
              Users
            </a>
          </li>
          <li>
            <a href="<%= basePath %>/settings/roles"
               class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                      <%= currentPath.includes('/settings/roles') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
              <i class="bi bi-shield-lock-fill text-lg"></i>
              User Roles
            </a>
          </li>
        <% } %>
        <li>
          <a href="<%= basePath %>/profile"
             class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                    <%= currentPath.includes('/profile') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
            <i class="bi bi-person-circle text-lg"></i>
            My Profile
          </a>
        </li>
        <% if (can('settings.view')) { %>
          <li>
            <a href="<%= basePath %>/settings"
               class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition
                      <%= currentPath.endsWith('/settings') ? 'bg-brand-50 text-brand-700' : 'text-ink-600 hover:bg-ink-100 hover:text-ink-900' %>">
              <i class="bi bi-gear-fill text-lg"></i>
              Settings
            </a>
          </li>
        <% } %>
        <li>
          <a href="<%= basePath %>/auth/logout"
             class="group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-ink-600 transition hover:bg-red-50 hover:text-red-700">
            <i class="bi bi-box-arrow-right text-lg"></i>
            Logout
          </a>
        </li>
      </ul>
    <% } %>
  </nav>

  <div class="flex-shrink-0 border-t border-ink-200 p-4">
    <div class="flex items-center gap-3 rounded-lg bg-ink-50 p-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-600 text-white font-semibold">
        <%= currentUser.name.charAt(0).toUpperCase() %>
      </div>
      <div class="min-w-0 flex-1">
        <p class="truncate text-sm font-semibold text-ink-900"><%= currentUser.name %></p>
        <p class="truncate text-xs text-ink-500"><%= currentUser.email %></p>
      </div>
    </div>
  </div>
</aside>

<div id="sidebar-backdrop"
     class="fixed inset-0 z-30 hidden bg-ink-900/50 lg:hidden"></div>
