<%
  const currentStatus = student.status || 'active';
  const statusTone = ({
    active:   { bg: 'bg-emerald-50', text: 'text-emerald-700', icon: 'bi-check-circle-fill' },
    on_leave: { bg: 'bg-amber-50',   text: 'text-amber-700',   icon: 'bi-pause-circle-fill' },
    left:     { bg: 'bg-ink-100',    text: 'text-ink-600',     icon: 'bi-box-arrow-right' },
  }[currentStatus]) || { bg: 'bg-ink-100', text: 'text-ink-600', icon: 'bi-circle' };

  // Local helper — same date format the rest of the app uses.
  const fmtDate = (iso) => iso
    ? new Date(iso).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })
    : '—';
  const fmtDateTime = (iso) => iso
    ? new Date(iso).toLocaleString('en-GB', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })
    : '—';

  const leaveCount   = presence.filter((r) => r.kind === 'leave').length;
  const totalLeaveD  = presence.filter((r) => r.kind === 'leave').reduce((s, r) => s + (r.days || 0), 0);
  const leftCount    = presence.filter((r) => r.kind === 'left').length;

  const presenceRow = (r) => {
    if (r.kind === 'enrolled') {
      return {
        tone: { bg: 'bg-brand-50',   text: 'text-brand-700',   icon: 'bi-door-open' },
        title: 'Enrolled',
        when:  fmtDate(r.at),
        detail: 'Joined the hostel',
      };
    }
    if (r.kind === 'leave') {
      return {
        tone: r.ongoing
          ? { bg: 'bg-amber-50',   text: 'text-amber-700',   icon: 'bi-pause-circle-fill' }
          : { bg: 'bg-amber-50',   text: 'text-amber-700',   icon: 'bi-pause-circle' },
        title: r.ongoing ? 'On leave (ongoing)' : 'On leave',
        when:  r.endedAt
          ? `${fmtDate(r.startedAt)} → ${fmtDate(r.endedAt)}`
          : `${fmtDate(r.startedAt)} → present`,
        detail: `${r.days} day${r.days === 1 ? '' : 's'}${r.ongoing ? ' so far' : ''}` +
                (r.startedBy ? ` · started by ${r.startedBy}` : '') +
                (r.endedBy ? ` · ended by ${r.endedBy}` : ''),
      };
    }
    if (r.kind === 'left') {
      return {
        tone: r.ongoing
          ? { bg: 'bg-ink-100',    text: 'text-ink-700',     icon: 'bi-box-arrow-right' }
          : { bg: 'bg-ink-100',    text: 'text-ink-700',     icon: 'bi-box-arrow-right' },
        title: r.ongoing ? 'Left hostel (current)' : 'Left hostel',
        when:  r.endedAt
          ? `${fmtDate(r.startedAt)} → ${fmtDate(r.endedAt)}`
          : `${fmtDate(r.startedAt)} → present`,
        detail: `${r.days} day${r.days === 1 ? '' : 's'}${r.ongoing ? ' so far' : ''}` +
                (r.startedBy ? ` · marked by ${r.startedBy}` : '') +
                (r.endedBy ? ` · re-activated by ${r.endedBy}` : ''),
      };
    }
    return null;
  };
%>

<div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
  <div>
    <a href="<%= basePath %>/students" class="text-sm text-ink-500 hover:text-ink-700">
      <i class="bi bi-arrow-left"></i> Back to students
    </a>
    <h2 class="mt-1 flex items-center gap-3 text-2xl font-bold text-ink-900">
      <% if (student.photo && student.photo.url) { %>
        <img src="<%= student.photo.url %>" class="h-10 w-10 rounded-full object-cover ring-2 ring-brand-100" />
      <% } else { %>
        <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-50 text-sm font-bold text-brand-600 ring-2 ring-brand-100">
          <%= student.name.charAt(0).toUpperCase() %>
        </span>
      <% } %>
      <span><%= student.name %> — History</span>
    </h2>
    <div class="mt-2 flex flex-wrap items-center gap-2">
      <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold <%= statusTone.bg %> <%= statusTone.text %>">
        <i class="bi <%= statusTone.icon %>"></i>
        <%= statusLabels[currentStatus] %>
      </span>
      <% if (room) { %>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700">
          <i class="bi bi-door-open-fill"></i> Room <%= room.roomNumber %>
        </span>
      <% } else { %>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-ink-100 px-2.5 py-1 text-xs font-semibold text-ink-600">
          <i class="bi bi-dash-circle"></i> Unassigned
        </span>
      <% } %>
      <% if (student.enrolledAt) { %>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-2.5 py-1 text-xs font-semibold text-brand-700">
          <i class="bi bi-calendar-event"></i> Enrolled <%= fmtDate(student.enrolledAt) %>
        </span>
      <% } %>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <a href="<%= basePath %>/students/<%= student.id %>"
       class="inline-flex items-center gap-2 rounded-lg border border-ink-200 bg-white px-4 py-2 text-sm font-semibold text-ink-700 hover:bg-ink-50">
      <i class="bi bi-person-vcard"></i> View profile
    </a>
  </div>
</div>

<!-- Summary stats -->
<div class="mb-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
  <div class="rounded-2xl border border-ink-200 bg-white p-4 shadow-card">
    <p class="text-xs font-semibold uppercase tracking-wide text-ink-500">Payments</p>
    <p class="mt-1 text-2xl font-bold text-ink-900"><%= payments.length %></p>
    <p class="mt-0.5 text-xs text-ink-500">
      Total <%= brand.currencySymbol %><%= totalPaid.toLocaleString() %>
    </p>
  </div>
  <div class="rounded-2xl border border-ink-200 bg-white p-4 shadow-card">
    <p class="text-xs font-semibold uppercase tracking-wide text-ink-500">Leaves taken</p>
    <p class="mt-1 text-2xl font-bold text-ink-900"><%= leaveCount %></p>
    <p class="mt-0.5 text-xs text-ink-500">
      <%= totalLeaveD %> day<%= totalLeaveD === 1 ? '' : 's' %> total
    </p>
  </div>
  <div class="rounded-2xl border border-ink-200 bg-white p-4 shadow-card">
    <p class="text-xs font-semibold uppercase tracking-wide text-ink-500">Left hostel</p>
    <p class="mt-1 text-2xl font-bold text-ink-900"><%= leftCount %></p>
    <p class="mt-0.5 text-xs text-ink-500">
      <%= student.leftAt ? 'Last ' + fmtDate(student.leftAt) : 'Never' %>
    </p>
  </div>
  <div class="rounded-2xl border border-ink-200 bg-white p-4 shadow-card">
    <p class="text-xs font-semibold uppercase tracking-wide text-ink-500">Enrolled for</p>
    <p class="mt-1 text-2xl font-bold text-ink-900">
      <% if (student.enrolledAt) { %>
        <% const ms = (student.leftAt ? new Date(student.leftAt) : new Date()).getTime() - new Date(student.enrolledAt).getTime(); %>
        <%= Math.max(Math.floor(ms / 86400000), 0) %>d
      <% } else { %>—<% } %>
    </p>
    <p class="mt-0.5 text-xs text-ink-500">Since enrollment</p>
  </div>
</div>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
  <!-- Presence timeline -->
  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="mb-4 flex items-center gap-2">
      <i class="bi bi-clock-history text-brand-600"></i>
      <h3 class="text-base font-semibold text-ink-900">Presence</h3>
      <span class="ml-auto rounded-full bg-ink-100 px-2 py-0.5 text-xs font-medium text-ink-600">
        <%= presence.length %> event<%= presence.length === 1 ? '' : 's' %>
      </span>
    </div>

    <% if (!presence.length) { %>
      <div class="rounded-xl border border-dashed border-ink-200 bg-ink-50 px-4 py-8 text-center">
        <i class="bi bi-calendar2-x text-2xl text-ink-400"></i>
        <p class="mt-2 text-sm text-ink-500">No presence events recorded yet.</p>
        <p class="mt-0.5 text-xs text-ink-400">Enrolled date and any leave / re-activation events will appear here.</p>
      </div>
    <% } else { %>
      <ol class="relative space-y-4 border-l-2 border-ink-100 pl-5">
        <% presence.forEach(function(r) {
             const row = presenceRow(r);
             if (!row) return; %>
          <li class="relative">
            <span class="absolute -left-[27px] top-1 flex h-6 w-6 items-center justify-center rounded-full ring-4 ring-white <%= row.tone.bg %> <%= row.tone.text %>">
              <i class="bi <%= row.tone.icon %> text-xs"></i>
            </span>
            <div class="rounded-xl border border-ink-100 bg-white p-3">
              <div class="flex flex-wrap items-baseline justify-between gap-x-3">
                <p class="text-sm font-semibold text-ink-900"><%= row.title %></p>
                <p class="text-xs text-ink-500"><%= row.when %></p>
              </div>
              <p class="mt-1 text-xs text-ink-500"><%= row.detail %></p>
            </div>
          </li>
        <% }) %>
      </ol>
    <% } %>
  </div>

  <!-- Payment history -->
  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="mb-4 flex items-center gap-2">
      <i class="bi bi-receipt text-brand-600"></i>
      <h3 class="text-base font-semibold text-ink-900">Payment history</h3>
      <span class="ml-auto rounded-full bg-ink-100 px-2 py-0.5 text-xs font-medium text-ink-600">
        <%= payments.length %>
      </span>
    </div>

    <% if (!payments.length) { %>
      <div class="rounded-xl border border-dashed border-ink-200 bg-ink-50 px-4 py-8 text-center">
        <i class="bi bi-cash-coin text-2xl text-ink-400"></i>
        <p class="mt-2 text-sm text-ink-500">No payments recorded yet.</p>
        <p class="mt-0.5 text-xs text-ink-400">Payments collected from <%= student.name %> will appear here.</p>
      </div>
    <% } else { %>
      <ul class="divide-y divide-ink-100">
        <% payments.forEach(function(p) { %>
          <li class="flex items-start justify-between gap-3 py-3 text-sm">
            <div class="min-w-0">
              <p class="text-base font-semibold text-ink-900">
                <%= brand.currencySymbol %><%= Number(p.amount).toLocaleString() %>
              </p>
              <p class="text-xs text-ink-500">
                <i class="bi bi-calendar3"></i> <%= fmtDateTime(p.paidAt) %>
                <% if (p.collectedBy) { %> · by <%= p.collectedBy %><% } %>
              </p>
              <% if (p.note) { %>
                <p class="mt-0.5 text-xs italic text-ink-500"><%= p.note %></p>
              <% } %>
            </div>
            <span class="shrink-0 rounded-full bg-ink-100 px-2.5 py-1 text-xs font-medium text-ink-700 capitalize">
              <%= p.method %>
            </span>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </div>
</div>
