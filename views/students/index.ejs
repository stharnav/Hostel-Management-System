<%
  // Small helper to keep the badge tone consistent everywhere.
  // `returned` is no longer a stored status (the "Mark as returned" button
  // lands the student in `active` directly); any legacy record that still
  // has the value falls through to the neutral gray tone below.
  function statusTone(s) {
    return ({
      active:   { bg: 'bg-emerald-50', text: 'text-emerald-700', dot: 'bg-emerald-500' },
      on_leave: { bg: 'bg-amber-50',   text: 'text-amber-700',   dot: 'bg-amber-500' },
      left:     { bg: 'bg-ink-100',    text: 'text-ink-600',     dot: 'bg-ink-400' },
    }[s] || { bg: 'bg-ink-100', text: 'text-ink-600', dot: 'bg-ink-400' });
  }
%>

<div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
  <div>
    <h2 class="text-2xl font-bold text-ink-900">Students</h2>
    <p class="mt-1 text-sm text-ink-500">Manage residents and their records</p>
  </div>
  <% if (can('students.create') && !tenantInactive) { %>
    <a href="<%= basePath %>/students/add"
       class="inline-flex items-center justify-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700">
      <i class="bi bi-person-plus-fill"></i>
      Add Student
    </a>
  <% } %>
</div>

<!-- Search + filter -->
<form method="GET" action="<%= basePath %>/students" class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center">
  <div class="relative flex-1">
    <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-ink-400">
      <i class="bi bi-search"></i>
    </span>
    <input type="search" name="q" value="<%= q %>" placeholder="Search by name, email, phone, institute…"
           class="w-full rounded-lg border border-ink-200 bg-white py-2.5 pl-10 pr-10 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
    <% if (q) { %>
      <a href="<%= basePath %>/students?status=<%= filter %>"
         class="absolute right-2 top-1/2 -translate-y-1/2 rounded p-1 text-ink-400 hover:bg-ink-100 hover:text-ink-700"
         title="Clear search">
        <i class="bi bi-x-lg"></i>
      </a>
    <% } %>
  </div>
  <input type="hidden" name="status" value="<%= filter %>" />
  <button type="submit"
          class="rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm font-semibold text-ink-700 hover:bg-ink-50">
    Search
  </button>
</form>

<!-- Filter pills -->
<%
  // Note: "Returned from leave" is no longer a stored status — the button
  // on the student view page lands the student in `active` directly (and
  // restarts the fee timer), so there's no "Returned" tab to filter by.
  const filterDefs = [
    { k: 'all',      l: 'All' },
    { k: 'active',   l: 'Active' },
    { k: 'on_leave', l: 'On leave' },
    { k: 'left',     l: 'Left hostel' },
  ];
%>
<div class="mb-4 flex flex-wrap items-center gap-2">
  <% filterDefs.forEach(function(f) {
       const active = f.k === filter;
       const url = basePath + '/students?status=' + f.k + (q ? ('&q=' + encodeURIComponent(q)) : ''); %>
    <a href="<%= url %>"
       class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm font-medium transition
              <%= active ? 'border-brand-600 bg-brand-600 text-white' : 'border-ink-200 bg-white text-ink-700 hover:bg-ink-100' %>">
      <%= f.l %>
      <span class="rounded-full px-1.5 text-xs
                   <%= active ? 'bg-white/20' : 'bg-ink-100 text-ink-600' %>"><%= counts[f.k] || 0 %></span>
    </a>
  <% }) %>
</div>

<div class="rounded-2xl border border-ink-200 bg-white shadow-card">
  <% if (!students.length) { %>
    <div class="px-6 py-16 text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-ink-100 text-ink-400">
        <i class="bi bi-search text-3xl"></i>
      </div>
      <h3 class="text-base font-semibold text-ink-900">
        <% if (q) { %>No students match "<%= q %>"<% } else { %>No students yet<% } %>
      </h3>
      <p class="mt-1 text-sm text-ink-500">
        <% if (q || filter !== 'all') { %>
          Try clearing the search or switching filters.
        <% } else { %>
          Get started by adding your first student.
        <% } %>
      </p>
      <% if (!q && filter === 'all' && !tenantInactive) { %>
        <a href="<%= basePath %>/students/add" class="mt-4 inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">
          <i class="bi bi-plus-lg"></i> Add student
        </a>
      <% } %>
    </div>
  <% } else { %>

    <!-- Mobile: card layout -->
    <div class="divide-y divide-ink-100 sm:hidden">
      <% students.forEach(function(s) {
           const st = s.status || 'active';
           const tone = statusTone(st);
           const isLeft = st === 'left'; %>
        <div class="block px-4 py-3 hover:bg-ink-50 transition cursor-pointer <%= isLeft ? 'opacity-60' : '' %>"
             data-student-row
             data-id="<%= s.id %>"
             data-name="<%= s.name.replace(/"/g, '&quot;') %>"
             data-status="<%= st %>">
          <div class="flex items-start gap-3">
            <% if (s.photo && s.photo.url) { %>
              <img src="<%= s.photo.url %>" class="h-10 w-10 rounded-full object-cover flex-shrink-0" alt="" />
            <% } else { %>
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-50 text-brand-600 font-semibold flex-shrink-0 text-sm">
                <%= s.name.charAt(0).toUpperCase() %>
              </div>
            <% } %>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <p class="text-sm font-semibold text-ink-900 truncate"><%= s.name %></p>
                <span class="inline-flex items-center gap-1 rounded-full px-1.5 py-0.5 text-[10px] font-semibold <%= tone.bg %> <%= tone.text %> flex-shrink-0">
                  <span class="h-1 w-1 rounded-full <%= tone.dot %>"></span>
                  <%= statusLabels[st] %>
                </span>
              </div>
              <div class="mt-0.5 flex items-center gap-2 text-xs text-ink-500">
                <% if (s.roomId) { %>
                  <span class="inline-flex rounded-full bg-emerald-50 px-1.5 py-0.5 text-[10px] font-medium text-emerald-700">Room assigned</span>
                <% } %>
                <% if (s.phone) { %>
                  <span><%= s.phone %></span>
                <% } %>
              </div>
              <% if (s.institute) { %>
                <p class="mt-0.5 text-[11px] text-ink-400 truncate"><%= s.institute %></p>
              <% } %>
            </div>
            <div class="flex items-center gap-1 flex-shrink-0" data-row-action-stop>
              <% if (can('students.viewProfile')) { %>
                <a href="<%= basePath %>/students/<%= s.id %>" class="rounded p-1.5 text-ink-400 hover:bg-brand-50 hover:text-brand-700">
                  <i class="bi bi-eye text-xs"></i>
                </a>
              <% } %>
              <% if (can('students.edit') && !tenantInactive) { %>
                <a href="<%= basePath %>/students/<%= s.id %>/edit" class="rounded p-1.5 text-ink-400 hover:bg-amber-50 hover:text-amber-700">
                  <i class="bi bi-pencil text-xs"></i>
                </a>
              <% } %>
              <% if (can('students.delete') && !tenantInactive) { %>
                <form method="POST" action="<%= basePath %>/students/<%= s.id %>?_method=DELETE" class="inline"
                      onsubmit="return confirm('Delete this student?')">
                  <button type="submit" class="rounded p-1.5 text-ink-400 hover:bg-red-50 hover:text-red-700">
                    <i class="bi bi-trash text-xs"></i>
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Desktop: table layout -->
    <div class="hidden sm:block overflow-x-auto">
      <table class="min-w-full divide-y divide-ink-200">
        <thead class="bg-ink-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-ink-500">Student</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-ink-500">Contact</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-ink-500">Institute</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-ink-500">Blood</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-ink-500">Room</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-ink-500">Status</th>
            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider text-ink-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-ink-100 bg-white">
          <% students.forEach(function(s) {
               const st = s.status || 'active';
               const tone = statusTone(st);
               const isLeft = st === 'left'; %>
            <tr class="hover:bg-ink-50 transition cursor-pointer <%= isLeft ? 'opacity-70' : '' %>"
                data-student-row
                data-id="<%= s.id %>"
                data-name="<%= s.name.replace(/"/g, '&quot;') %>"
                data-status="<%= st %>">
              <td class="whitespace-nowrap px-6 py-4">
                <div class="flex items-center gap-3">
                  <% if (s.photo && s.photo.url) { %>
                    <img src="<%= s.photo.url %>" class="h-10 w-10 rounded-full object-cover" alt="" />
                  <% } else { %>
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-50 text-brand-600 font-semibold">
                      <%= s.name.charAt(0).toUpperCase() %>
                    </div>
                  <% } %>
                  <div>
                    <p class="text-sm font-semibold text-ink-900"><%= s.name %></p>
                    <% if (s.nameNepali) { %>
                      <p class="text-xs text-ink-500"><%= s.nameNepali %></p>
                    <% } else { %>
                      <p class="text-xs text-ink-500"><%= s.email %></p>
                    <% } %>
                  </div>
                </div>
              </td>
              <td class="whitespace-nowrap px-6 py-4 text-sm text-ink-700">
                <div><%= s.phone %></div>
                <div class="text-xs text-ink-500"><%= s.email %></div>
              </td>
              <td class="whitespace-nowrap px-6 py-4 text-sm text-ink-700">
                <div><%= s.institute || '—' %></div>
                <% if (s.levelOfStudy) { %>
                  <div class="text-xs text-ink-500"><%= s.levelOfStudy %></div>
                <% } %>
              </td>
              <td class="whitespace-nowrap px-6 py-4">
                <% if (s.bloodGroup) { %>
                  <span class="inline-flex rounded-full bg-red-50 px-2.5 py-0.5 text-xs font-semibold text-red-700"><%= s.bloodGroup %></span>
                <% } else { %>
                  <span class="text-xs text-ink-400">—</span>
                <% } %>
              </td>
              <td class="whitespace-nowrap px-6 py-4">
                <% if (s.roomId) { %>
                  <span class="inline-flex rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-medium text-emerald-700">Assigned</span>
                <% } else { %>
                  <span class="inline-flex rounded-full bg-ink-100 px-2.5 py-0.5 text-xs font-medium text-ink-600">Unassigned</span>
                <% } %>
              </td>
              <td class="whitespace-nowrap px-6 py-4">
                <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-semibold <%= tone.bg %> <%= tone.text %>">
                  <span class="h-1.5 w-1.5 rounded-full <%= tone.dot %>"></span>
                  <%= statusLabels[st] %>
                </span>
              </td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm">
                <div class="inline-flex items-center gap-1" data-row-action-stop>
                  <% if (can('students.viewProfile')) { %>
                    <a href="<%= basePath %>/students/<%= s.id %>" title="View"
                       class="rounded-lg p-2 text-ink-500 hover:bg-brand-50 hover:text-brand-700">
                      <i class="bi bi-eye"></i>
                    </a>
                  <% } %>
                  <% if (can('students.edit') && !tenantInactive) { %>
                    <a href="<%= basePath %>/students/<%= s.id %>/edit" title="Edit"
                       class="rounded-lg p-2 text-ink-500 hover:bg-amber-50 hover:text-amber-700">
                      <i class="bi bi-pencil"></i>
                    </a>
                  <% } %>
                  <% if (can('students.delete') && !tenantInactive) { %>
                    <form method="POST" action="<%= basePath %>/students/<%= s.id %>?_method=DELETE" class="inline"
                          onsubmit="return confirm('Delete this student?')">
                      <button type="submit" title="Delete"
                              class="rounded-lg p-2 text-ink-500 hover:bg-red-50 hover:text-red-700">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  <% } %>
</div>

<!-- Row-action modal — populated by the click handler below. Buttons are
     rendered server-side so each is gated by `can()` (no permission leaks
     via dev tools). Lifecycle transitions are real POST forms, so the page
     still works with JS off. -->
<div id="student-row-modal"
     class="fixed inset-0 z-50 hidden items-center justify-center p-4"
     role="dialog" aria-modal="true" aria-labelledby="student-row-modal-title">
  <div id="student-row-modal-backdrop"
       class="absolute inset-0 bg-ink-900/60 backdrop-blur-sm"></div>
  <div class="relative w-full max-w-sm rounded-2xl bg-white p-6 shadow-2xl ring-1 ring-ink-200">
    <div class="flex items-start gap-3">
      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
        <i class="bi bi-person-circle text-xl"></i>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-xs font-medium text-ink-500">Student actions</p>
        <h3 id="student-row-modal-title"
            class="truncate text-base font-semibold text-ink-900">—</h3>
        <p id="student-row-modal-subtitle" class="mt-0.5 text-xs text-ink-500">—</p>
      </div>
      <button type="button" data-modal-close
              class="rounded p-1 text-ink-400 hover:bg-ink-100 hover:text-ink-700"
              aria-label="Close">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <div class="mt-5 flex flex-col gap-2">
      <%# View / Edit / History — simple links. Gated by their respective permissions. %>
      <% if (can('students.viewProfile')) { %>
        <a id="srm-view" href="#"
           class="inline-flex items-center gap-3 rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm font-semibold text-ink-800 hover:bg-brand-50 hover:border-brand-300 hover:text-brand-700">
          <i class="bi bi-eye text-lg text-brand-600"></i> View profile
        </a>
      <% } %>
      <% if (can('students.viewHistory')) { %>
        <a id="srm-history" href="#"
           class="inline-flex items-center gap-3 rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm font-semibold text-ink-800 hover:bg-indigo-50 hover:border-indigo-300 hover:text-indigo-700">
          <i class="bi bi-clock-history text-lg text-indigo-600"></i> View history
        </a>
      <% } %>
      <% if (can('students.edit') && !tenantInactive) { %>
        <a id="srm-edit" href="#"
           class="inline-flex items-center gap-3 rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm font-semibold text-ink-800 hover:bg-amber-50 hover:border-amber-300 hover:text-amber-700">
          <i class="bi bi-pencil-square text-lg text-amber-600"></i> Edit profile
        </a>
      <% } %>

      <%# Lifecycle transitions. Each is a real form POST so it works without
          JS. Buttons that don't make sense for the current status (e.g. Mark
          on leave for a student who already left) are hidden by the click
          handler — but we still server-render them with data-status-key
          attributes so the handler can toggle them. %>
      <% if (can('students.changeStatus') && !tenantInactive) { %>
        <div class="my-1 border-t border-ink-100"></div>
        <p class="px-1 text-[11px] font-semibold uppercase tracking-wider text-ink-400">Lifecycle</p>
        <%# Hidden by default; shown by the click handler when the row's
            current status permits the transition. %>
        <form id="srm-form-leave" method="POST" action="#" data-show-for="active"
              onsubmit="return confirm('Mark this student as on leave?')"
              class="hidden">
          <input type="hidden" name="status" value="on_leave" />
          <button class="inline-flex w-full items-center gap-3 rounded-lg border border-amber-200 bg-amber-50 px-4 py-2.5 text-sm font-semibold text-amber-700 hover:bg-amber-100">
            <i class="bi bi-pause-circle-fill text-lg"></i> Mark on leave
          </button>
        </form>
        <%# "Mark as active" works for both on_leave (returned → active) and
            left (re-activate). The controller maps `returned` to `active`. %>
        <form id="srm-form-active" method="POST" action="#" data-show-for="on_leave,left"
              onsubmit="return confirm('Mark this student as active again? Fee timer will restart from today.')"
              class="hidden">
          <input type="hidden" name="status" value="returned" />
          <button class="inline-flex w-full items-center gap-3 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-2.5 text-sm font-semibold text-emerald-700 hover:bg-emerald-100">
            <i class="bi bi-arrow-counterclockwise text-lg"></i> Mark as active
          </button>
        </form>
        <form id="srm-form-left" method="POST" action="#" data-show-for="active,on_leave"
              onsubmit="return confirm('Mark this student as left? Their room will be freed.')"
              class="hidden">
          <input type="hidden" name="status" value="left" />
          <button class="inline-flex w-full items-center gap-3 rounded-lg border border-red-200 bg-red-50 px-4 py-2.5 text-sm font-semibold text-red-700 hover:bg-red-100">
            <i class="bi bi-box-arrow-right text-lg"></i> Mark as left
          </button>
        </form>
      <% } %>

      <p id="srm-empty" class="hidden rounded-lg bg-ink-50 px-3 py-2 text-xs text-ink-500">
        You don't have permission for any actions on this student.
      </p>
    </div>
  </div>
</div>

<script>
  const BASE = '<%= basePath %>';
  // Row-action modal: clicking a student row opens a popup with the
  // actions available for that student. Inline action icons in the last
  // column set data-row-action-stop, so they don't trigger this.
  document.addEventListener('DOMContentLoaded', function () {
    const modal = document.getElementById('student-row-modal');
    if (!modal) return;

    const title = document.getElementById('student-row-modal-title');
    const subtitle = document.getElementById('student-row-modal-subtitle');
    const viewLink = document.getElementById('srm-view');
    const editLink = document.getElementById('srm-edit');
    const historyLink = document.getElementById('srm-history');
    const emptyMsg = document.getElementById('srm-empty');
    const lifecycleForms = modal.querySelectorAll('form[data-show-for]');
    const backdrop = document.getElementById('student-row-modal-backdrop');
    const closers = modal.querySelectorAll('[data-modal-close]');

    const STATUS_LABEL = {
      active: 'Active',
      on_leave: 'On leave',
      left: 'Left hostel',
      returned: 'Returned (legacy)',
    };

    let lastFocused = null;

    function open(row) {
      const id = row.dataset.id;
      const name = row.dataset.name || 'Student';
      const status = row.dataset.status || 'active';

      title.textContent = name;
      subtitle.textContent = `Status: ${STATUS_LABEL[status] || status}`;

      if (viewLink) viewLink.href = BASE + '/students/' + encodeURIComponent(id);
      if (editLink) editLink.href = BASE + '/students/' + encodeURIComponent(id) + '/edit';
      if (historyLink) historyLink.href = BASE + '/students/' + encodeURIComponent(id) + '/history';

      // Show only the lifecycle buttons that make sense for the row's
      // current status. Buttons that don't apply are hidden — they remain
      // in the DOM so a future status change takes effect on the next
      // page load (i.e. no JS-only state to keep in sync).
      const allowed = (form) => {
        const keys = (form.dataset.showFor || '').split(',').map(s => s.trim());
        return keys.includes(status);
      };
      let visibleCount = 0;
      lifecycleForms.forEach((form) => {
        if (allowed(form)) {
          form.action = BASE + '/students/' + encodeURIComponent(id) + '/status';
          form.classList.remove('hidden');
          visibleCount++;
        } else {
          form.classList.add('hidden');
        }
      });

      // If the user has no actions at all, show a friendly note.
      const hasAny = (viewLink || editLink || historyLink) || visibleCount > 0;
      if (emptyMsg) emptyMsg.classList.toggle('hidden', hasAny);

      lastFocused = document.activeElement;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      // Focus the first focusable element inside the modal for keyboard users.
      const firstFocusable = modal.querySelector(
        'a, button, [tabindex]:not([tabindex="-1"])'
      );
      if (firstFocusable) firstFocusable.focus();
    }

    function close() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      if (lastFocused && typeof lastFocused.focus === 'function') {
        lastFocused.focus();
      }
    }

    // Row click → open. Skip clicks that originated inside the inline
    // action cell (those have data-row-action-stop on the wrapper).
    document.querySelectorAll('[data-student-row]').forEach((row) => {
      row.addEventListener('click', (e) => {
        if (e.target.closest('[data-row-action-stop]')) return;
        // If the click was on a link or button inside the row other than
        // the action cell, let it through (covers accidental edge cases).
        if (e.target.closest('a, button, form')) return;
        open(row);
      });
      // Keyboard support: pressing Enter on a focused row opens the popup.
      row.tabIndex = 0;
      row.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          open(row);
        }
      });
    });

    closers.forEach((el) => el.addEventListener('click', close));
    backdrop.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });
  });
</script>

