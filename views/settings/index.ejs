<div class="mb-6">
  <h2 class="text-2xl font-bold text-ink-900">Settings</h2>
  <p class="mt-1 text-sm text-ink-500">Branding, roles, usage, and system info</p>
</div>

<% if (currentUser.role === 'admin') { %>
  <!-- Quick link to role management. Kept compact so the page still
       leads with branding and system info. -->
  <a href="/settings/roles"
     class="mb-6 flex items-center justify-between gap-4 rounded-2xl border border-brand-200 bg-gradient-to-r from-brand-50 via-white to-emerald-50 p-4 shadow-card transition hover:border-brand-300 hover:shadow-soft">
    <div class="flex items-center gap-3">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-600 text-white shadow">
        <i class="bi bi-shield-lock-fill text-xl"></i>
      </div>
      <div>
        <p class="text-sm font-medium text-ink-500">Access control</p>
        <p class="text-base font-semibold text-ink-900">User Roles &amp; Permissions</p>
        <p class="text-xs text-ink-500">Create roles and choose what each user type can do.</p>
      </div>
    </div>
    <i class="bi bi-chevron-right text-2xl text-brand-500"></i>
  </a>
<% } %>

<!-- Branding -->
<div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
  <div class="mb-5 flex items-center gap-2">
    <i class="bi bi-palette-fill text-brand-600"></i>
    <h3 class="text-base font-semibold text-ink-900">App Branding &amp; Currency</h3>
    <% if (currentUser.role !== 'admin') { %>
      <span class="ml-auto rounded-full bg-ink-100 px-2.5 py-0.5 text-xs font-medium text-ink-600">Admin only</span>
    <% } %>
  </div>

  <form method="POST" action="/settings/branding" enctype="multipart/form-data">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      <!-- Icon preview + upload -->
      <div class="md:col-span-1">
        <label class="mb-1.5 block text-sm font-medium text-ink-700">App icon</label>
        <div class="flex flex-col items-center rounded-xl border-2 border-dashed border-ink-200 bg-ink-50 p-5">
          <% if (brand.iconUrl) { %>
            <img src="<%= brand.iconUrl %>" alt="App icon"
                 class="h-20 w-20 rounded-2xl object-cover shadow ring-1 ring-ink-200" />
          <% } else { %>
            <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-brand-600 text-white shadow">
              <i class="bi bi-building text-3xl"></i>
            </div>
          <% } %>
          <p class="mt-3 text-xs text-ink-500">Square PNG/JPG, auto-resized to 256×256</p>

          <% if (currentUser.role === 'admin') { %>
            <label class="mt-3 inline-flex cursor-pointer items-center gap-2 rounded-lg border border-ink-200 bg-white px-3 py-1.5 text-sm font-medium text-ink-700 hover:bg-brand-50 hover:border-brand-300 hover:text-brand-700">
              <i class="bi bi-upload"></i> Choose image
              <input type="file" name="icon" accept="image/*" class="hidden"
                     onchange="this.parentElement.querySelector('span').textContent = this.files[0]?.name || ''" />
            </label>
            <span class="mt-2 text-xs text-ink-500"></span>
          <% } %>
        </div>

        <% if (currentUser.role === 'admin' && brand.iconUrl) { %>
          <form method="POST" action="/settings/branding/reset-icon" class="mt-2"
                onsubmit="return confirm('Remove the custom icon and revert to default?')">
            <button class="text-xs font-medium text-red-600 hover:underline">
              <i class="bi bi-x-circle"></i> Reset to default icon
            </button>
          </form>
        <% } %>
      </div>

      <!-- App name + actions -->
      <div class="md:col-span-2">
        <label class="mb-1.5 block text-sm font-medium text-ink-700">App name</label>
        <input name="appName" value="<%= brand.appName %>" maxlength="60"
               <%= currentUser.role === 'admin' ? '' : 'disabled' %>
               class="w-full rounded-lg border border-ink-200 bg-white px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100 disabled:bg-ink-50" />
        <p class="mt-1 text-xs text-ink-500">
          Shown in the sidebar, navbar title, login screen, and browser tab.
        </p>

        <!-- Currency -->
        <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div class="sm:col-span-1">
            <label class="mb-1.5 block text-sm font-medium text-ink-700">Currency symbol</label>
            <input name="currencySymbol" value="<%= brand.currencySymbol || 'Rs.' %>" maxlength="5"
                   <%= currentUser.role === 'admin' ? '' : 'disabled' %>
                   class="w-full rounded-lg border border-ink-200 bg-white px-3 py-2.5 text-center text-base font-semibold focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100 disabled:bg-ink-50" />
          </div>
          <div class="sm:col-span-2">
            <label class="mb-1.5 block text-sm font-medium text-ink-700">Currency code</label>
            <input name="currencyCode" value="<%= brand.currencyCode || 'NPR' %>" maxlength="5"
                   placeholder="INR / NPR / USD / EUR …"
                   <%= currentUser.role === 'admin' ? '' : 'disabled' %>
                   class="w-full rounded-lg border border-ink-200 bg-white px-3 py-2.5 text-sm uppercase focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100 disabled:bg-ink-50" />
          </div>
          <p class="sm:col-span-3 text-xs text-ink-500">
            Used everywhere money is shown — room rent, fees, etc.
            Common symbols: <code class="rounded bg-ink-100 px-1.5">₹</code>
            <code class="rounded bg-ink-100 px-1.5">रु</code>
            <code class="rounded bg-ink-100 px-1.5">$</code>
            <code class="rounded bg-ink-100 px-1.5">€</code>
            <code class="rounded bg-ink-100 px-1.5">£</code>
            <code class="rounded bg-ink-100 px-1.5">¥</code>
          </p>
        </div>

        <% if (currentUser.role === 'admin') { %>
          <div class="mt-5 flex items-center justify-end gap-3">
            <a href="/settings" class="rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm font-semibold text-ink-700 hover:bg-ink-50">Cancel</a>
            <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700">
              <i class="bi bi-check2"></i> Save settings
            </button>
          </div>
        <% } else { %>
          <p class="mt-5 rounded-lg bg-amber-50 px-3 py-2 text-sm text-amber-700">
            <i class="bi bi-lock-fill"></i> Only admins can change branding.
          </p>
        <% } %>
      </div>
    </div>
  </form>
</div>

<!-- Storage usage -->
<%
  // Spark (free) plan limits: 5 GB Storage, 1 GB Firestore data.
  const storageQuotaGB = 5;
  const firestoreQuotaGB = 1;
  const storageQuotaBytes = storageQuotaGB * 1024 * 1024 * 1024;
  const firestoreQuotaBytes = firestoreQuotaGB * 1024 * 1024 * 1024;
  const storagePct = Math.min(100, (storage.bytes / storageQuotaBytes) * 100);
  const firestorePct = Math.min(100, (firestore.bytes / firestoreQuotaBytes) * 100);
%>

<div class="mt-6 grid grid-cols-1 gap-6 lg:grid-cols-2">
  <!-- Storage bucket -->
  <div class="rounded-2xl border border-ink-200 bg-gradient-to-br from-purple-50 via-white to-brand-50 p-6 shadow-card">
    <div class="flex items-center gap-3">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-purple-500 to-brand-600 text-white shadow">
        <i class="bi bi-hdd-fill text-xl"></i>
      </div>
      <div>
        <p class="text-sm font-medium text-ink-500">Firebase Storage</p>
        <p class="text-2xl font-bold text-ink-900"><%= storage.formatted %></p>
      </div>
    </div>
    <div class="mt-4">
      <div class="mb-1.5 flex items-center justify-between text-xs">
        <span class="font-medium text-ink-600"><%= storage.fileCount %> file<%= storage.fileCount === 1 ? '' : 's' %></span>
        <span class="font-semibold text-brand-700"><%= storagePct.toFixed(2) %>% of <%= storageQuotaGB %> GB</span>
      </div>
      <div class="h-2.5 w-full overflow-hidden rounded-full bg-white/70">
        <div class="h-full rounded-full bg-gradient-to-r from-brand-500 to-purple-600 transition-all"
             data-width="<%= storagePct %>"></div>
      </div>
    </div>
    <p class="mt-3 text-xs text-ink-500">
      Total bytes of all objects in the configured Storage bucket.
    </p>
  </div>

  <!-- Firestore -->
  <div class="rounded-2xl border border-ink-200 bg-gradient-to-br from-amber-50 via-white to-emerald-50 p-6 shadow-card">
    <div class="flex items-center gap-3">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-amber-500 to-emerald-600 text-white shadow">
        <i class="bi bi-database-fill text-xl"></i>
      </div>
      <div>
        <p class="text-sm font-medium text-ink-500">Firestore data <span class="text-xs text-ink-400">(approx.)</span></p>
        <p class="text-2xl font-bold text-ink-900"><%= firestore.formatted %></p>
      </div>
    </div>
    <div class="mt-4">
      <div class="mb-1.5 flex items-center justify-between text-xs">
        <span class="font-medium text-ink-600"><%= firestore.docCount %> document<%= firestore.docCount === 1 ? '' : 's' %></span>
        <span class="font-semibold text-emerald-700"><%= firestorePct.toFixed(2) %>% of <%= firestoreQuotaGB %> GB</span>
      </div>
      <div class="h-2.5 w-full overflow-hidden rounded-full bg-white/70">
        <div class="h-full rounded-full bg-gradient-to-r from-amber-500 to-emerald-600 transition-all"
             data-width="<%= firestorePct %>"></div>
      </div>
    </div>
    <p class="mt-3 text-xs text-ink-500">
      Estimated by serializing each document to JSON and summing UTF-8 byte
      length. The Admin SDK does not expose true storage size — see the
      <a href="https://console.firebase.google.com" target="_blank" class="text-brand-600 hover:underline">Firebase Console</a>
      for the exact figure.
    </p>
  </div>
</div>

<!-- Per-collection breakdown -->
<div class="mt-6 rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
  <div class="mb-4 flex items-center gap-2">
    <i class="bi bi-collection-fill text-brand-600"></i>
    <h3 class="text-base font-semibold text-ink-900">Collections breakdown</h3>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-ink-200">
      <thead class="bg-ink-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wider text-ink-500">Collection</th>
          <th class="px-4 py-2 text-right text-xs font-semibold uppercase tracking-wider text-ink-500">Documents</th>
          <th class="px-4 py-2 text-right text-xs font-semibold uppercase tracking-wider text-ink-500">Approx. size</th>
          <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wider text-ink-500">Share</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink-100">
        <% firestore.collections.forEach(function(c) {
             const share = firestore.bytes ? (c.bytes / firestore.bytes) * 100 : 0; %>
          <tr>
            <td class="px-4 py-3 text-sm font-semibold text-ink-900"><%= c.name %></td>
            <td class="px-4 py-3 text-right text-sm text-ink-700"><%= c.docs %></td>
            <td class="px-4 py-3 text-right text-sm font-mono text-ink-700"><%= c.formatted %></td>
            <td class="px-4 py-3 w-1/3">
              <div class="flex items-center gap-2">
                <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-ink-100">
                  <div class="h-full rounded-full bg-brand-500" data-width="<%= share %>"></div>
                </div>
                <span class="w-12 text-right text-xs text-ink-500"><%= share.toFixed(1) %>%</span>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- System info -->
<div class="mt-6 rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
  <div class="mb-4 flex items-center gap-2">
    <i class="bi bi-cpu-fill text-brand-600"></i>
    <h3 class="text-base font-semibold text-ink-900">System information</h3>
  </div>
  <dl class="divide-y divide-ink-100 text-sm">
    <div class="flex items-center justify-between py-3">
      <dt class="text-ink-500">Node.js version</dt>
      <dd class="font-mono font-semibold text-ink-900"><%= system.nodeVersion %></dd>
    </div>
    <div class="flex items-center justify-between py-3">
      <dt class="text-ink-500">Platform</dt>
      <dd class="font-mono text-ink-900"><%= system.platform %></dd>
    </div>
    <div class="flex items-center justify-between py-3">
      <dt class="text-ink-500">Server uptime</dt>
      <dd class="font-semibold text-ink-900"><%= system.uptime %> s</dd>
    </div>
    <div class="flex items-start justify-between py-3 gap-3">
      <dt class="text-ink-500">Storage bucket</dt>
      <dd class="font-mono text-right text-xs text-ink-900 break-all"><%= system.bucket %></dd>
    </div>
    <div class="flex items-center justify-between py-3">
      <dt class="text-ink-500">Signed in as</dt>
      <dd class="flex items-center gap-2">
        <span class="text-sm font-semibold text-ink-900"><%= currentUser.name %></span>
        <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold uppercase
                     <%= currentUser.role === 'admin' ? 'bg-red-50 text-red-700' : 'bg-blue-50 text-blue-700' %>">
          <%= currentUser.role %>
        </span>
      </dd>
    </div>
  </dl>
</div>
