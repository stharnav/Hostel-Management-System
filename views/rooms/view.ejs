<div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
  <div>
    <a href="/rooms" class="text-sm text-ink-500 hover:text-ink-700">
      <i class="bi bi-arrow-left"></i> Back to rooms
    </a>
    <h2 class="mt-1 text-2xl font-bold text-ink-900">Room <%= room.roomNumber %></h2>
  </div>
  <div class="flex items-center gap-2">
    <a href="/rooms/<%= room.id %>/edit"
       class="inline-flex items-center gap-2 rounded-lg border border-ink-200 bg-white px-4 py-2 text-sm font-semibold text-ink-700 hover:bg-ink-50">
      <i class="bi bi-pencil"></i> Edit
    </a>
    <% if (currentUser.role === 'admin') { %>
      <form method="POST" action="/rooms/<%= room.id %>?_method=DELETE" class="inline"
            onsubmit="return confirm('Delete this room?')">
        <button class="inline-flex items-center gap-2 rounded-lg border border-red-200 bg-white px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50">
          <i class="bi bi-trash"></i> Delete
        </button>
      </form>
    <% } %>
  </div>
</div>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <!-- Room details -->
  <div class="space-y-6">
    <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
      <h4 class="mb-4 text-sm font-semibold uppercase tracking-wide text-ink-500">Details</h4>
      <dl class="space-y-3 text-sm">
        <div class="flex items-center justify-between"><dt class="text-ink-500">Type</dt><dd class="font-semibold text-ink-900"><%= room.type %></dd></div>
        <div class="flex items-center justify-between"><dt class="text-ink-500">Floor</dt><dd class="font-semibold text-ink-900"><%= room.floor || '—' %></dd></div>
        <div class="flex items-center justify-between"><dt class="text-ink-500">Capacity</dt><dd class="font-semibold text-ink-900"><%= room.capacity %> beds</dd></div>
        <div class="flex items-center justify-between"><dt class="text-ink-500">Rent</dt><dd class="font-semibold text-ink-900"><%= brand.currencySymbol %><%= room.rent || 0 %>/mo</dd></div>
        <div class="flex items-center justify-between">
          <dt class="text-ink-500">Status</dt>
          <dd>
            <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold
                         <%= room.status === 'available' ? 'bg-emerald-50 text-emerald-700' : (room.status === 'occupied' ? 'bg-red-50 text-red-700' : 'bg-amber-50 text-amber-700') %>">
              <%= room.status %>
            </span>
          </dd>
        </div>
      </dl>
    </div>

    <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
      <h4 class="mb-4 text-sm font-semibold uppercase tracking-wide text-ink-500">Assign student</h4>
      <% if ((room.occupants || []).length >= room.capacity) { %>
        <p class="rounded-lg bg-amber-50 px-3 py-2 text-sm text-amber-700">Room is at full capacity.</p>
      <% } else if (!unassigned.length) { %>
        <p class="rounded-lg bg-ink-50 px-3 py-2 text-sm text-ink-600">No unassigned students available.</p>
      <% } else { %>
        <form method="POST" action="/rooms/<%= room.id %>/assign" class="space-y-3">
          <select name="studentId" required class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100">
            <% unassigned.forEach(function(s) { %>
              <option value="<%= s.id %>"><%= s.name %> (<%= s.email %>)</option>
            <% }) %>
          </select>
          <button class="w-full inline-flex items-center justify-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-700">
            <i class="bi bi-person-plus-fill"></i> Assign
          </button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- Occupants -->
  <div class="lg:col-span-2 rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="mb-4 flex items-center justify-between">
      <h4 class="text-sm font-semibold uppercase tracking-wide text-ink-500">Occupants</h4>
      <span class="text-sm font-semibold text-ink-700"><%= occupants.length %> / <%= room.capacity %></span>
    </div>
    <% if (!occupants.length) { %>
      <div class="rounded-xl bg-ink-50 px-4 py-8 text-center">
        <i class="bi bi-people text-3xl text-ink-300"></i>
        <p class="mt-2 text-sm text-ink-500">No one assigned yet</p>
      </div>
    <% } else { %>
      <ul class="space-y-2">
        <% occupants.forEach(function(s) { %>
          <li class="flex items-center gap-3 rounded-xl border border-ink-100 bg-white p-3 hover:bg-ink-50">
            <% if (s.photo && s.photo.url) { %>
              <img src="<%= s.photo.url %>" class="h-10 w-10 rounded-full object-cover" />
            <% } else { %>
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-50 text-brand-600 font-semibold">
                <%= s.name.charAt(0).toUpperCase() %>
              </div>
            <% } %>
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-semibold text-ink-900"><%= s.name %></p>
              <p class="truncate text-xs text-ink-500"><%= s.email %> · <%= s.phone %></p>
            </div>
            <a href="/students/<%= s.id %>" class="rounded-lg p-2 text-ink-500 hover:bg-brand-50 hover:text-brand-700">
              <i class="bi bi-eye"></i>
            </a>
            <form method="POST" action="/rooms/<%= room.id %>/unassign" class="inline"
                  onsubmit="return confirm('Remove this student from room?')">
              <input type="hidden" name="studentId" value="<%= s.id %>" />
              <button class="rounded-lg p-2 text-ink-500 hover:bg-red-50 hover:text-red-700">
                <i class="bi bi-x-lg"></i>
              </button>
            </form>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </div>
</div>
