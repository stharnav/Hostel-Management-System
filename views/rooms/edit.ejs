<% if (tenantInactive) { %>
<div class="rounded-2xl border border-ink-200 bg-white p-12 text-center shadow-card">
  <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-amber-100 text-amber-600">
    <i class="bi bi-lock-fill text-3xl"></i>
  </div>
  <h3 class="text-base font-semibold text-ink-900">Hostel is inactive</h3>
  <p class="mt-1 text-sm text-ink-500">You cannot edit rooms while the hostel is inactive.</p>
  <a href="<%= basePath %>/rooms/<%= room.id %>" class="mt-4 inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">
    <i class="bi bi-arrow-left"></i> Back to room
  </a>
</div>
<% } else { %>
<div class="mb-6">
  <h2 class="text-2xl font-bold text-ink-900">Edit Room</h2>
  <p class="mt-1 text-sm text-ink-500">Update room details</p>
</div>

<form method="POST" action="<%= basePath %>/rooms/<%= room.id %>?_method=PUT" class="space-y-6">
  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Room number *</label>
        <input name="roomNumber" value="<%= room.roomNumber %>" required class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Type</label>
        <select name="type" class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100">
          <% ['Standard','Deluxe','AC','Non-AC'].forEach(function(t){ %>
            <option <%= room.type === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Capacity *</label>
        <input type="number" min="1" name="capacity" value="<%= room.capacity %>" required class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Floor</label>
        <input name="floor" value="<%= room.floor || '' %>" class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Rent (<%= brand.currencySymbol %>)</label>
        <input type="number" min="0" name="rent" value="<%= room.rent || 0 %>" class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100" />
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-700">Status</label>
        <select name="status" class="w-full rounded-lg border border-ink-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-100">
          <option value="available" <%= room.status === 'available' ? 'selected' : '' %>>Available</option>
          <option value="occupied" <%= room.status === 'occupied' ? 'selected' : '' %>>Occupied</option>
          <option value="maintenance" <%= room.status === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
        </select>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <a href="<%= basePath %>/rooms/<%= room.id %>" class="rounded-lg border border-ink-200 bg-white px-4 py-2.5 text-sm font-semibold text-ink-700 hover:bg-ink-50">Cancel</a>
    <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700">
      <i class="bi bi-check2"></i> Update
    </button>
  </div>
</form>
<% } %>
