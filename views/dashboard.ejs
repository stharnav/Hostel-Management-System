<div class="mb-4">
  <h2 class="text-2xl font-bold text-ink-900">Hello, <%= currentUser.name.split(' ')[0] %> 👋</h2>
  <p class="mt-1 text-sm text-ink-500">Here's what's happening with your hostel today.</p>
</div>

<!-- Stat cards -->
<div class="grid grid-cols-2 gap-3 sm:grid-cols-2 xl:grid-cols-4">
  <div class="rounded-2xl border border-ink-200 bg-white p-3 sm:p-4 shadow-card">
    <div class="flex items-center justify-between">
      <div class="flex h-9 w-9 sm:h-12 sm:w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
        <i class="bi bi-people-fill text-base sm:text-xl"></i>
      </div>
      <span class="rounded-full bg-emerald-50 px-1.5 sm:px-2 py-0.5 text-[10px] sm:text-xs font-medium text-emerald-700">Active</span>
    </div>
    <p class="mt-2 sm:mt-3 text-xs sm:text-sm font-medium text-ink-500">Students</p>
    <p class="mt-0.5 text-2xl sm:text-3xl font-bold text-ink-900"><%= stats.students %></p>
  </div>

  <div class="rounded-2xl border border-ink-200 bg-white p-3 sm:p-4 shadow-card">
    <div class="flex items-center justify-between">
      <div class="flex h-9 w-9 sm:h-12 sm:w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
        <i class="bi bi-door-closed-fill text-base sm:text-xl"></i>
      </div>
    </div>
    <p class="mt-2 sm:mt-3 text-xs sm:text-sm font-medium text-ink-500">Rooms</p>
    <p class="mt-0.5 text-2xl sm:text-3xl font-bold text-ink-900"><%= stats.rooms %></p>
  </div>

  <div class="rounded-2xl border border-ink-200 bg-white p-3 sm:p-4 shadow-card">
    <div class="flex items-center justify-between">
      <div class="flex h-9 w-9 sm:h-12 sm:w-12 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600">
        <i class="bi bi-person-check-fill text-base sm:text-xl"></i>
      </div>
      <% const pct = stats.capacity ? Math.round((stats.occupied / stats.capacity) * 100) : 0; %>
      <span class="rounded-full bg-indigo-50 px-1.5 sm:px-2 py-0.5 text-[10px] sm:text-xs font-medium text-indigo-700"><%= pct %>%</span>
    </div>
    <p class="mt-2 sm:mt-3 text-xs sm:text-sm font-medium text-ink-500">Occupied</p>
    <p class="mt-0.5 text-2xl sm:text-3xl font-bold text-ink-900"><%= stats.occupied %> <span class="text-sm sm:text-base font-medium text-ink-400">/ <%= stats.capacity %></span></p>
  </div>

  <div class="rounded-2xl border border-ink-200 bg-white p-3 sm:p-4 shadow-card">
    <div class="flex items-center justify-between">
      <div class="flex h-9 w-9 sm:h-12 sm:w-12 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
        <i class="bi bi-house-add-fill text-base sm:text-xl"></i>
      </div>
    </div>
    <p class="mt-2 sm:mt-3 text-xs sm:text-sm font-medium text-ink-500">Vacant</p>
    <p class="mt-0.5 text-2xl sm:text-3xl font-bold text-ink-900"><%= stats.vacancies %></p>
  </div>
</div>

<!-- Quick actions + occupancy -->
<div class="mt-4 sm:mt-6 grid grid-cols-1 gap-4 sm:gap-6 lg:grid-cols-3">
  <div class="lg:col-span-2 rounded-2xl border border-ink-200 bg-white p-4 sm:p-6 shadow-card">
    <div class="flex items-center justify-between">
      <h3 class="text-base sm:text-lg font-semibold text-ink-900">Occupancy</h3>
      <span class="text-xs sm:text-sm text-ink-500"><%= stats.occupied %>/<%= stats.capacity %></span>
    </div>
    <div class="mt-4 sm:mt-6">
      <div class="mb-2 flex items-center justify-between text-xs sm:text-sm">
        <span class="font-medium text-ink-700">Utilization</span>
        <span class="font-semibold text-brand-600"><%= pct %>%</span>
      </div>
      <div class="h-2.5 sm:h-3 w-full overflow-hidden rounded-full bg-ink-100">
        <div class="h-full rounded-full bg-gradient-to-r from-brand-500 to-brand-700 transition-all"
             data-width="<%= pct %>"></div>
      </div>
    </div>
    <div class="mt-4 sm:mt-6 grid grid-cols-3 gap-2 sm:gap-4 text-center">
      <div class="rounded-xl bg-ink-50 p-2.5 sm:p-4">
        <p class="text-[10px] sm:text-xs font-medium text-ink-500">Occupied</p>
        <p class="mt-0.5 sm:mt-1 text-lg sm:text-xl font-bold text-ink-900"><%= stats.occupied %></p>
      </div>
      <div class="rounded-xl bg-ink-50 p-2.5 sm:p-4">
        <p class="text-[10px] sm:text-xs font-medium text-ink-500">Vacant</p>
        <p class="mt-0.5 sm:mt-1 text-lg sm:text-xl font-bold text-ink-900"><%= stats.vacancies %></p>
      </div>
      <div class="rounded-xl bg-ink-50 p-2.5 sm:p-4">
        <p class="text-[10px] sm:text-xs font-medium text-ink-500">Capacity</p>
        <p class="mt-0.5 sm:mt-1 text-lg sm:text-xl font-bold text-ink-900"><%= stats.capacity %></p>
      </div>
    </div>
  </div>

  <div class="rounded-2xl border border-ink-200 bg-white p-4 sm:p-6 shadow-card">
    <h3 class="text-base sm:text-lg font-semibold text-ink-900">Quick actions</h3>
    <p class="mt-1 text-xs sm:text-sm text-ink-500">Jump to common tasks</p>
    <div class="mt-3 sm:mt-4 space-y-2">
      <a href="/students/add"
         class="flex items-center gap-3 rounded-lg border border-ink-200 px-3 sm:px-4 py-2.5 sm:py-3 text-xs sm:text-sm font-medium text-ink-700 transition hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700">
        <i class="bi bi-person-plus-fill text-base"></i>
        Add new student
      </a>
      <a href="/rooms/add"
         class="flex items-center gap-3 rounded-lg border border-ink-200 px-3 sm:px-4 py-2.5 sm:py-3 text-xs sm:text-sm font-medium text-ink-700 transition hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700">
        <i class="bi bi-door-open-fill text-base"></i>
        Add new room
      </a>
      <% if (currentUser.role === 'admin') { %>
        <a href="/users/add"
           class="flex items-center gap-3 rounded-lg border border-ink-200 px-3 sm:px-4 py-2.5 sm:py-3 text-xs sm:text-sm font-medium text-ink-700 transition hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700">
          <i class="bi bi-person-badge-fill text-base"></i>
          Add user account
        </a>
      <% } %>
      <% if (can('expenses.create')) { %>
        <a href="/expenses/add"
           class="flex items-center gap-3 rounded-lg border border-ink-200 px-3 sm:px-4 py-2.5 sm:py-3 text-xs sm:text-sm font-medium text-ink-700 transition hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700">
          <i class="bi bi-receipt-cutoff text-base"></i>
          Add expense
        </a>
      <% } %>
    </div>
  </div>
</div>

<!-- Expenses overview -->
<% if (stats.recentExpenses && stats.recentExpenses.length > 0) { %>
<div class="mt-4 sm:mt-6 rounded-2xl border border-ink-200 bg-white p-4 sm:p-6 shadow-card">
  <div class="flex items-center justify-between">
    <h3 class="text-base sm:text-lg font-semibold text-ink-900">Recent Expenses</h3>
    <a href="/expenses" class="text-xs sm:text-sm font-medium text-brand-600 hover:text-brand-700">View all &rarr;</a>
  </div>
  <div class="mt-3 sm:mt-4 grid grid-cols-2 gap-3 sm:gap-4">
    <div class="rounded-xl bg-indigo-50 p-3 sm:p-4">
      <p class="text-[10px] sm:text-xs font-medium text-ink-500">This Month</p>
      <p class="mt-0.5 sm:mt-1 text-lg sm:text-2xl font-bold text-ink-900"><%= brand.currencySymbol || '₹' %><%= stats.monthExpenses.toLocaleString('en-IN') %></p>
    </div>
    <div class="rounded-xl bg-amber-50 p-3 sm:p-4">
      <p class="text-[10px] sm:text-xs font-medium text-ink-500">All Time</p>
      <p class="mt-0.5 sm:mt-1 text-lg sm:text-2xl font-bold text-ink-900"><%= brand.currencySymbol || '₹' %><%= stats.totalExpenses.toLocaleString('en-IN') %></p>
    </div>
  </div>

  <!-- Desktop: table -->
  <div class="mt-3 sm:mt-4 hidden sm:block overflow-x-auto">
    <table class="min-w-full divide-y divide-ink-200">
      <thead>
        <tr>
          <th class="px-4 py-2 text-left text-xs font-semibold uppercase text-ink-500">Date</th>
          <th class="px-4 py-2 text-left text-xs font-semibold uppercase text-ink-500">Category</th>
          <th class="px-4 py-2 text-left text-xs font-semibold uppercase text-ink-500">Description</th>
          <th class="px-4 py-2 text-right text-xs font-semibold uppercase text-ink-500">Amount</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ink-100">
        <% stats.recentExpenses.forEach(function(e) { %>
          <tr class="hover:bg-ink-50">
            <td class="whitespace-nowrap px-4 py-3 text-sm text-ink-700">
              <%= e.date ? new Date(e.date).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—' %>
            </td>
            <td class="whitespace-nowrap px-4 py-3">
              <span class="inline-flex items-center rounded-full border border-brand-200 bg-brand-50 px-2 py-0.5 text-xs font-semibold text-brand-700">
                <%= e.category || 'Misc' %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm text-ink-700 truncate max-w-xs"><%= e.description || '—' %></td>
            <td class="whitespace-nowrap px-4 py-3 text-right text-sm font-semibold text-ink-900"><%= brand.currencySymbol || '₹' %><%= (e.amount || 0).toLocaleString('en-IN') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Mobile: compact list -->
  <div class="mt-3 sm:hidden divide-y divide-ink-100">
    <% stats.recentExpenses.forEach(function(e) { %>
      <a href="/expenses" class="flex items-center justify-between py-2.5 hover:bg-ink-50 transition">
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center rounded-full border border-brand-200 bg-brand-50 px-1.5 py-0.5 text-[10px] font-semibold text-brand-700">
              <%= e.category || 'Misc' %>
            </span>
            <span class="text-[11px] text-ink-400"><%= e.date ? new Date(e.date).toLocaleDateString('en-GB', { day:'2-digit', month:'short' }) : '' %></span>
          </div>
          <% if (e.description) { %>
            <p class="mt-0.5 text-xs text-ink-600 truncate"><%= e.description %></p>
          <% } %>
        </div>
        <p class="ml-3 text-sm font-bold text-ink-900 flex-shrink-0"><%= brand.currencySymbol || '₹' %><%= (e.amount || 0).toLocaleString('en-IN') %></p>
      </a>
    <% }) %>
  </div>
</div>
<% } %>
