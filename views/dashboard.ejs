<div class="mb-6">
  <h2 class="text-2xl font-bold text-ink-900">Hello, <%= currentUser.name.split(' ')[0] %> 👋</h2>
  <p class="mt-1 text-sm text-ink-500">Here's what's happening with your hostel today.</p>
</div>

<!-- Stat cards -->
<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="flex items-center justify-between">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
        <i class="bi bi-people-fill text-xl"></i>
      </div>
      <span class="rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">Active</span>
    </div>
    <p class="mt-4 text-sm font-medium text-ink-500">Total Students</p>
    <p class="mt-1 text-3xl font-bold text-ink-900"><%= stats.students %></p>
  </div>

  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="flex items-center justify-between">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
        <i class="bi bi-door-closed-fill text-xl"></i>
      </div>
    </div>
    <p class="mt-4 text-sm font-medium text-ink-500">Total Rooms</p>
    <p class="mt-1 text-3xl font-bold text-ink-900"><%= stats.rooms %></p>
  </div>

  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="flex items-center justify-between">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600">
        <i class="bi bi-person-check-fill text-xl"></i>
      </div>
      <% const pct = stats.capacity ? Math.round((stats.occupied / stats.capacity) * 100) : 0; %>
      <span class="rounded-full bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-700"><%= pct %>%</span>
    </div>
    <p class="mt-4 text-sm font-medium text-ink-500">Occupied Beds</p>
    <p class="mt-1 text-3xl font-bold text-ink-900"><%= stats.occupied %> <span class="text-base font-medium text-ink-400">/ <%= stats.capacity %></span></p>
  </div>

  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="flex items-center justify-between">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
        <i class="bi bi-house-add-fill text-xl"></i>
      </div>
    </div>
    <p class="mt-4 text-sm font-medium text-ink-500">Vacant Beds</p>
    <p class="mt-1 text-3xl font-bold text-ink-900"><%= stats.vacancies %></p>
  </div>
</div>

<!-- Quick actions + occupancy -->
<div class="mt-6 grid grid-cols-1 gap-6 lg:grid-cols-3">
  <div class="lg:col-span-2 rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-semibold text-ink-900">Occupancy overview</h3>
      <span class="text-sm text-ink-500"><%= stats.occupied %> of <%= stats.capacity %> beds</span>
    </div>
    <div class="mt-6">
      <div class="mb-2 flex items-center justify-between text-sm">
        <span class="font-medium text-ink-700">Capacity utilization</span>
        <span class="font-semibold text-brand-600"><%= pct %>%</span>
      </div>
      <div class="h-3 w-full overflow-hidden rounded-full bg-ink-100">
        <div class="h-full rounded-full bg-gradient-to-r from-brand-500 to-brand-700 transition-all"
             data-width="<%= pct %>"></div>
      </div>
    </div>
    <div class="mt-6 grid grid-cols-3 gap-4 text-center">
      <div class="rounded-xl bg-ink-50 p-4">
        <p class="text-xs font-medium text-ink-500">Occupied</p>
        <p class="mt-1 text-xl font-bold text-ink-900"><%= stats.occupied %></p>
      </div>
      <div class="rounded-xl bg-ink-50 p-4">
        <p class="text-xs font-medium text-ink-500">Vacant</p>
        <p class="mt-1 text-xl font-bold text-ink-900"><%= stats.vacancies %></p>
      </div>
      <div class="rounded-xl bg-ink-50 p-4">
        <p class="text-xs font-medium text-ink-500">Capacity</p>
        <p class="mt-1 text-xl font-bold text-ink-900"><%= stats.capacity %></p>
      </div>
    </div>
  </div>

  <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-card">
    <h3 class="text-lg font-semibold text-ink-900">Quick actions</h3>
    <p class="mt-1 text-sm text-ink-500">Jump to common tasks</p>
    <div class="mt-4 space-y-2">
      <a href="/students/add"
         class="flex items-center gap-3 rounded-lg border border-ink-200 px-4 py-3 text-sm font-medium text-ink-700 transition hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700">
        <i class="bi bi-person-plus-fill text-lg"></i>
        Add new student
      </a>
      <a href="/rooms/add"
         class="flex items-center gap-3 rounded-lg border border-ink-200 px-4 py-3 text-sm font-medium text-ink-700 transition hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700">
        <i class="bi bi-door-open-fill text-lg"></i>
        Add new room
      </a>
      <% if (currentUser.role === 'admin') { %>
        <a href="/users/add"
           class="flex items-center gap-3 rounded-lg border border-ink-200 px-4 py-3 text-sm font-medium text-ink-700 transition hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700">
          <i class="bi bi-person-badge-fill text-lg"></i>
          Add user account
        </a>
      <% } %>
    </div>
  </div>
</div>
